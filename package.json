{
  "name": "rhttp.io",
  "version": "1.0.4",
  "description": "Universal HTTP client with caching, retries, circuit breaker, JWT auth, CSRF protection, and Socket.io",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "http",
    "fetch",
    "isomorphic",
    "universal",
    "client",
    "cache",
    "retry",
    "circuit-breaker",
    "jwt",
    "csrf",
    "validation",
    "typescript",
    "react",
    "socket.io",
    "realtime"
  ],
  "author": "http.io Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elprof45/rhttp.io.git"
  },
  "bugs": {
    "url": "https://github.com/elprof45/rhttp.io/issues"
  },
  "homepage": "https://rhttpio.netlify.app",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./socket.io.client": {
      "import": {
        "types": "./dist/socket.io.d.ts",
        "default": "./dist/socket.io.js"
      },
      "require": {
        "types": "./dist/socket.io.d.cts",
        "default": "./dist/socket.io.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "bun test",
    "lint": "tsc --noEmit",
    "prepublishOnly": "bun run build && bun run test && npm version patch"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.45.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^18.3.3",
    "react": "^18.3.1",
    "socket.io-client": "^4.8.3",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "socket.io-client": "^4.8.3"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "socket.io-client": {
      "optional": true
    }
  }
}
